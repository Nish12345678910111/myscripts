-- ANTI FLING
-- ============================================================
local antiFlingConn = nil
function enableAntiFling()
    if antiFlingConn then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    antiFlingConn = RunService.Stepped:Connect(function()
        if not hrp or not hrp.Parent then antiFlingConn:Disconnect(); antiFlingConn = nil; return end
        local vel = hrp.AssemblyLinearVelocity
        if vel.Magnitude > 100 then hrp.AssemblyLinearVelocity = vel.Unit * 100 end
        local av = hrp.AssemblyAngularVelocity
        if av.Magnitude > 50 then hrp.AssemblyAngularVelocity = av.Unit * 50 end
    end)
end
function disableAntiFling()
    if antiFlingConn then antiFlingConn:Disconnect(); antiFlingConn = nil end
end
if Data.settings.antiFling then
    LocalPlayer.CharacterAdded:Connect(function(c) task.wait(0.5); enableAntiFling() end)
    if LocalPlayer.Character then task.wait(0.5); enableAntiFling() end
end

