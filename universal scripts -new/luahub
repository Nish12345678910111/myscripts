-- ============================================================
-- AUTO EXECUTION LOGIC
-- ============================================================
local function isPlaceIdInList(placeIds, currentId)
    if not placeIds or type(placeIds) ~= "table" then return false end
    local idStr = tostring(currentId)
    for _, pid in ipairs(placeIds) do
        if tostring(pid) == idStr then return true end
    end
    return false
end

local function runScriptCode(src)
    if src == "" then return end
    local loader = loadstring or load
    if loader then
        local ok, fn = pcall(loader, src)
        if ok and type(fn) == "function" then pcall(fn) end
    end
end

local function executeAutoExecScripts()
    if not Data.settings.isKeyValid then return end
    local currentPlaceId = game.PlaceId
    local allScripts = {}
    for _, t in ipairs(Data.autoExecTabs) do
        if t.enabled then table.insert(allScripts, t) end
    end
    for _, t in ipairs(Data.tabs) do
        if t.enabled then table.insert(allScripts, t) end
    end
    if #allScripts == 0 then return end
    if Data.settings.performanceMode then
        showPerfNotif("PERFORMANCE MODE", "Starting execution...", "")
        task.wait(0.5)
        for i, t in ipairs(allScripts) do
            local fps = math.floor(workspace:GetRealPhysicsFPS())
            local warnTxt = fps < 30 and "Warning: Low FPS ("..fps..")" or ""
            showPerfNotif("EXECUTING ("..i.."/"..#allScripts..")", "Running: " .. (t.name or "Script"), warnTxt)
            if t.globalExecute then
                runScriptCode(t.code or "")
            else
                if isPlaceIdInList(t.placeIds, currentPlaceId) then
                    runScriptCode(t.code or "")
                end
            end
            task.wait(0.5)
        end
        hidePerfNotif()
    else
        for _, t in ipairs(allScripts) do
            if t.globalExecute then
                task.spawn(runScriptCode, t.code or "")
            else
                if isPlaceIdInList(t.placeIds, currentPlaceId) then
                    task.spawn(runScriptCode, t.code or "")
                end
            end
        end
    end
end

