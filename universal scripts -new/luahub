-- UTILITY PAGE — Pathfind (with speed INPUT) + ESP + Aimlock
-- ============================================================
local pathfindingActive = false
local currentPath = nil
local wpIdx = 1
local lastPathCalc = 0
local PATH_INTERVAL = 0.2

local function getNearestPlayer()
    local char = LocalPlayer.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local nearest, minDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local pHRP = p.Character:FindFirstChild("HumanoidRootPart")
            if pHRP then
                local d = (pHRP.Position - hrp.Position).Magnitude
                if d < minDist then minDist = d; nearest = p end
            end
        end
    end
    return nearest
end

RunService.Heartbeat:Connect(function(dt)
    if not pathfindingActive then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end
    hum.WalkSpeed = Data.settings.pathSpeed or 100
    local target = getNearestPlayer()
    if not target or not target.Character then return end
    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
    if not targetHRP then return end
    local dist = (targetHRP.Position - hrp.Position).Magnitude
    if dist < 4 then return end
    if tick() - lastPathCalc > PATH_INTERVAL or not currentPath then
        local path = PathfindingService:CreatePath({
            AgentRadius = 3, AgentHeight = 5, AgentCanJump = true, WaypointSpacing = 4
        })
        local ok = pcall(function() path:ComputeAsync(hrp.Position, targetHRP.Position) end)
        if ok and path.Status == Enum.PathStatus.Success then
            currentPath = path:GetWaypoints(); wpIdx = 2
        else
            currentPath = nil; hum:MoveTo(targetHRP.Position)
        end
        lastPathCalc = tick()
    end
    if currentPath and wpIdx <= #currentPath then
        local wp = currentPath[wpIdx]; hum:MoveTo(wp.Position)
        if (hrp.Position - wp.Position).Magnitude < 6 then wpIdx = wpIdx + 1 end
    elseif not currentPath then
        hum:MoveTo(targetHRP.Position)
    end
end)

